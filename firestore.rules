rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'high200sunny@gmail.com');
    }

    function isUserDoc(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'high200sunny@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isApprovedUser() {
      return isSignedIn() && (
        request.auth.token.email == 'high200sunny@gmail.com' || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
        )
      );
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && request.auth.uid == uid && 
        request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'role', 'status', 'createdAt']) &&
        request.resource.data.keys().size() == 7 &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        (request.auth.token.email == 'high200sunny@gmail.com' ? 
          (request.resource.data.role == 'admin' && request.resource.data.status == 'approved') : 
          (request.resource.data.role == 'visitor' && request.resource.data.status == 'pending')
        );

      allow update: if isSignedIn() && (
        isAdmin() || (
          request.auth.uid == uid && 
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status
        )
      );
      
      allow delete: if isAdmin();
    }

    // Groups collection
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isApprovedUser() && (getUserRole() == 'admin' || getUserRole() == 'school' || getUserRole() == 'public');
      allow update: if isApprovedUser() && (getUserRole() == 'admin' || getUserRole() == 'school' || getUserRole() == 'public');
      allow delete: if isAdmin();
    }

    // Parts collection
    match /parts/{partId} {
      allow read: if isSignedIn();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isApprovedUser();
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isApprovedUser();
    }

    // Expenses collection
    match /expenses/{expenseId} {
      allow read: if isSignedIn();
      allow create: if isApprovedUser();
      allow update: if isApprovedUser();
      allow delete: if isApprovedUser();
    }
  }
}
